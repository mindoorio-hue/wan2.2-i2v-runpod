{
  "tests": [
    {
      "name": "basic_480p_generation",
      "input": {
        "image": "",
        "prompt": "A colorful parrot perched on a branch, gently moving its feathers in a light breeze.",
        "resolution": "480p",
        "num_frames": 17,
        "num_inference_steps": 10,
        "guidance_scale": 3.5,
        "fps": 8,
        "seed": 42
      },
      "timeout": 600000
    },
    {
      "name": "no_prompt_generation",
      "input": {
        "image": "",
        "prompt": "",
        "resolution": "480p",
        "num_frames": 17,
        "num_inference_steps": 10,
        "guidance_scale": 3.5,
        "fps": 8,
        "seed": 0
      },
      "timeout": 600000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA A100 80GB PCIe",
    "gpuCount": 1,
    "allowedCudaVersions": ["12.8", "12.7", "12.6", "12.5", "12.4", "12.3", "12.2", "12.1", "12.0"],
    "env": [
      {"key": "MODEL_ID", "value": "Wan-AI/Wan2.2-I2V-A14B-Diffusers"},
      {"key": "RESOLUTION", "value": "480p"},
      {"key": "ENABLE_CPU_OFFLOAD", "value": "false"}
    ]
  }
